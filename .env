# Configuração do motor de recomendação (04_recommender), lida por config.py.
#
# ARQUIVO VERSIONADO: contém APENAS caminhos e parâmetros — NUNCA segredos
# (tokens, senhas). O token do Hugging Face, por exemplo, fica em
# ~/.cache/huggingface/token, fora do repositório.
#
# Caminhos relativos são resolvidos a partir da raiz do repositório.
# Variáveis já definidas no ambiente têm precedência sobre este arquivo.

# --- Paths importantes ---
# Fonte única (val+test inferido pelo melhor modelo, BERTimbau) usada tanto para
# o corpus quanto para a vitrine, garantindo coerência.
RECOMMENDER_INFERRED_CSV=data/results_from_best_model/B2W-Reviews01_inferred_bertimbau.csv

# Diretório onde o build grava os artefatos (índice, catálogos, embeddings).
RECOMMENDER_ARTIFACTS=04_recommender/artifacts

# --- Overrides opcionais (descomente se precisar) ---
# RECOMMENDER_LABEL_COLUMN=inferencia_bertimbau
# RECOMMENDER_MIN_REVIEWS=5
# RECOMMENDER_DEVICE=cuda
# RECOMMENDER_MODEL=Qwen/Qwen3-Embedding-0.6B
# RECOMMENDER_ALPHA=0.7
# RECOMMENDER_TOP_N=10
